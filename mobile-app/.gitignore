# Node modules
node_modules/

# Environment variables
.env
.env.local

# Expo folders & files
.expo/
dist/
web-build/

# Native build folders (Since we are using Expo prebuild/dev-client, 
# these are autogenerated and shouldn't be committed unless you manually edit native code)
android/
ios/

# Log files
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# macOS/Windows system files
.DS_Store
Thumbs.db

# Keystores and provisioning profiles (Important for security)
*.jks
*.p8
*.p12
*.key
*.mobileprovision

# Detached Expo apps (just in case)
expo-shared/